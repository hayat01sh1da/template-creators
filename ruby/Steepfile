# frozen_string_literal: true

target :app do
  check 'main.rb'
  check 'exec'
  check 'src'
  ignore 'test'
  signature 'sig'

  library 'date'
  library 'fileutils'

  configure_code_diagnostics(Steep::Diagnostic::Ruby.default)
end

target :test do
  ignore 'main.rb'
  ignore 'exec'
  ignore 'src'
  check 'test'
  signature 'sig'

  library 'fileutils'
  library 'minitest'

  configure_code_diagnostics(Steep::Diagnostic::Ruby.default)
end
